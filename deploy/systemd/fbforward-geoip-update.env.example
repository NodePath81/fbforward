# Copy to /etc/default/fbforward-geoip with mode 0600.
# The token must match control.auth_token in /etc/fbforward/config.yaml.
FBFORWARD_CONTROL_URL=http://127.0.0.1:8080
FBFORWARD_CONTROL_TOKEN=replace-with-the-control-token

# Optional mirror for hosts that cannot reach raw.githubusercontent.com:
# LOYALSOLDIER_GEOIP_BASE_URL=https://cdn.jsdelivr.net/gh/Loyalsoldier/geoip@release
